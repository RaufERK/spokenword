{
  "name": "spokenword-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.12.0",
    "npm": ">=11.7.0"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:upload": "cd upload-service && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dblist": "npx prisma studio",
    "deploy:eu": "bash scripts/deploy-eu.sh",
    "pg:start": "docker compose up -d",
    "pg:stop": "docker compose stop",
    "pg:reset": "docker compose down -v && docker compose up -d",
    "pg:use": "cp .env.pg .env && echo 'Switched to PostgreSQL'",
    "deploy": "pm2 deploy ecosystem.config.cjs production",
    "seed": "node prisma/seed.js",
    "db:export": "node scripts/export-data.js",
    "db:backup": "node scripts/backup-database.cjs",
    "db:restore": "node scripts/restore-database.cjs",
    "conf:restore": "node scripts/restore-conference-archive.cjs",
    "cleanup": "node scripts/cleanup-orphan-files.cjs",
    "cleanup:dry": "node scripts/cleanup-orphan-files.cjs --dry-run --verbose",
    "logs": "ssh app 'bash /home/appuser/apps/spokenword/source/scripts/watch-logs.sh'",
    "logs:errors": "ssh app 'tail -f /home/appuser/logs/spokenword-error.log'",
    "logs:output": "ssh app 'tail -f /home/appuser/logs/spokenword-out.log'",
    "logs:nginx:ru": "ssh sw 'tail -f /var/log/nginx/www_spoken_word_access.log'",
    "logs:nginx:eu": "ssh amster 'tail -f /var/log/nginx/spoken_word_info_access.log'"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "^6.10.1",
    "@tailwindcss/postcss": "^4",
    "hls.js": "^1.6.2",
    "ioredis": "^5.8.2",
    "lucide-react": "^0.525.0",
    "next": "^16.0.10",
    "next-auth": "^4.24.11",
    "prisma": "^6.10.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4",
    "transliteration": "^2.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.9.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
