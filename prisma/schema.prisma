generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER
}

enum EventType {
  CONFERENCE
  CLASS
}

enum PaymentStatus {
  ACTIVE
  REVOKED
}

enum ChatRoomType {
  GENERAL
  SUPPORT
  PRIVATE
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String
  lastName     String
  city         String?
  login        String    @unique
  password     String
  phoneNumber  String?   @unique
  email        String?   @unique
  accessUntil  DateTime?
  telegramId   String?   @unique
  birthYear    Int?
  joinedYear   Int?
  isPrivileged Boolean   @default(false)
  isAbroad     Boolean   @default(false)
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  uploadedPackages     ContentPackage[]    @relation("UploadedPackages")
  packageAccess        UserPackageAccess[]
  grantedPackageAccess UserPackageAccess[] @relation("GrantedPackageAccess")
  eventAccess          UserEventAccess[]
  grantedEventAccess   UserEventAccess[]   @relation("GrantedEventAccess")
  revokedEventAccess   UserEventAccess[]   @relation("RevokedEventAccess")
  chatMessages         ChatMessage[]
  chatRoomParticipants ChatRoomParticipant[]

  @@index([accessUntil])
}

model Event {
  id         Int       @id @default(autoincrement())
  title      String
  type       EventType @default(CONFERENCE)
  startDate  DateTime
  accessDays Int       @default(30)
  createdAt  DateTime  @default(now())

  payments UserEventAccess[]
  files    ConferenceFile[]
}

model UserEventAccess {
  id          Int           @id @default(autoincrement())
  userId      Int
  eventId     Int
  paymentDate DateTime      @default(now())
  grantedBy   Int
  status      PaymentStatus @default(ACTIVE)
  revokedBy   Int?
  revokedAt   DateTime?

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event @relation(fields: [eventId], references: [id])
  admin   User  @relation("GrantedEventAccess", fields: [grantedBy], references: [id])
  revoker User? @relation("RevokedEventAccess", fields: [revokedBy], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model ConferenceFile {
  id           Int      @id @default(autoincrement())
  displayName  String
  originalName String
  systemName   String   @unique
  uploadedAt   DateTime @default(now())
  uploadedBy   Int
  size         BigInt
  views        Int      @default(0)
  duration     Int?
  isPublic     Boolean  @default(false)
  orderIndex   Int      @default(0)
  eventId      Int?

  event Event? @relation(fields: [eventId], references: [id])
}

model StreamLink {
  id         Int      @id @default(autoincrement())
  youtubeUrl String?
  rutubeUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ChannelPost {
  id                Int      @id @default(autoincrement())
  telegramMessageId Int
  channelId         String
  channelUsername   String?
  telegramDate      DateTime
  text              String?
  textEntities      Json?
  hashtags          String[] @default([])
  mediaType         String?
  imageUrl          String?
  isDeleted         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([channelId, telegramMessageId])
  @@index([isDeleted, telegramDate(sort: Desc)])
}

model ContentPackage {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  price       Decimal
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uploadedBy  Int

  items     PackageItem[]
  purchases UserPackageAccess[]
  uploader  User                @relation("UploadedPackages", fields: [uploadedBy], references: [id])
}

model PackageItem {
  id             Int      @id @default(autoincrement())
  packageId      Int
  title          String
  fileName       String
  originalName   String   @default("")
  filePath       String
  duration       Int?
  orderIndex     Int
  originalSize   BigInt
  compressedSize BigInt
  createdAt      DateTime @default(now())

  package ContentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId, orderIndex])
  @@index([packageId, originalName, originalSize])
}

model ClassFile {
  id           Int      @id @default(autoincrement())
  displayName  String
  originalName String
  systemName   String   @unique
  uploadedAt   DateTime @default(now())
  uploadedBy   Int
  size         BigInt
  views        Int      @default(0)
  duration     Int?
  isPublic     Boolean  @default(false)
  orderIndex   Int      @default(0)
}

model ClassStreamLink {
  id         Int      @id @default(autoincrement())
  youtubeUrl String?
  rutubeUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ChatRoom {
  id        Int          @id @default(autoincrement())
  type      ChatRoomType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  messages     ChatMessage[]
  participants ChatRoomParticipant[]
}

model ChatRoomParticipant {
  id         Int       @id @default(autoincrement())
  roomId     Int
  userId     Int
  lastReadAt DateTime?

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  roomId    Int
  userId    Int
  text      String
  link      String?
  reactions String   @default("{}")
  createdAt DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([createdAt])
}

model UserPackageAccess {
  id           Int      @id @default(autoincrement())
  userId       Int
  packageId    Int
  purchaseDate DateTime @default(now())
  price        Decimal
  grantedBy    Int
  notes        String?

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  package ContentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  admin   User           @relation("GrantedPackageAccess", fields: [grantedBy], references: [id])

  @@unique([userId, packageId])
  @@index([userId])
  @@index([packageId])
}
