generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  city         String?
  login        String   @unique
  password     String
  phoneNumber  String?  @unique
  email        String?  @unique
  paymentDate  DateTime?
  telegramId   String?  @unique
  birthYear    Int?
  joinedYear   Int?
  isPrivileged Boolean  @default(false)
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([paymentDate])
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER
}


model ConferenceFile {
  id           Int      @id @default(autoincrement())
  displayName  String   // Красивое имя
  originalName String   // Имя при загрузке
  systemName   String   @unique
  uploadedAt   DateTime @default(now())
  uploadedBy   Int
  size         Int
  views        Int      @default(0)
}

model StreamLink {
  id        Int      @id @default(autoincrement())
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
