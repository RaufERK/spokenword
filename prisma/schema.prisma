generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String
  lastName     String
  city         String?
  login        String    @unique
  password     String
  phoneNumber  String?   @unique
  email        String?   @unique
  paymentDate  DateTime? // фактическая дата последней оплаты (аудит)
  accessUntil  DateTime? // дата окончания доступа (= max(paymentDate, event.startDate) + 30 дней)
  telegramId   String?   @unique
  birthYear    Int?
  joinedYear   Int?
  isPrivileged Boolean   @default(false)
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  uploadedPackages     ContentPackage[]    @relation("UploadedPackages")
  packageAccess        UserPackageAccess[]
  grantedPackageAccess UserPackageAccess[] @relation("GrantedPackageAccess")
  eventAccess          UserEventAccess[]
  grantedEventAccess   UserEventAccess[]   @relation("GrantedEventAccess")
  chatMessages         ChatMessage[]

  @@index([paymentDate])
  @@index([accessUntil])
}

enum EventType {
  CONFERENCE
  CLASS
}

model Event {
  id        Int       @id @default(autoincrement())
  title     String
  type      EventType @default(CONFERENCE)
  startDate DateTime
  createdAt DateTime  @default(now())

  payments  UserEventAccess[]
}

model UserEventAccess {
  id          Int      @id @default(autoincrement())
  userId      Int
  eventId     Int
  paymentDate DateTime @default(now())
  grantedBy   Int

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event @relation(fields: [eventId], references: [id])
  admin       User  @relation("GrantedEventAccess", fields: [grantedBy], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
}

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPER
}


model ConferenceFile {
  id           Int      @id @default(autoincrement())
  displayName  String   // Красивое имя
  originalName String   // Имя при загрузке
  systemName   String   @unique
  uploadedAt   DateTime @default(now())
  uploadedBy   Int
  size         BigInt   // Changed to BigInt for files > 2GB
  views        Int      @default(0)
  duration     Int?     // Длительность в секундах
  isPublic     Boolean  @default(false) // Видимость для обычных пользователей
  orderIndex   Int      @default(0)    // Кастомный порядок сортировки
}

model StreamLink {
  id         Int      @id @default(autoincrement())
  youtubeUrl String?  // Ссылка на YouTube
  rutubeUrl  String?  // Ссылка на Rutube
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Платные материалы - пакеты лекций
model ContentPackage {
  id          Int      @id @default(autoincrement())
  title       String   // "Курс медитации - 13 лекций"
  description String?  // Подробное описание пакета
  price       Decimal  // Цена за весь пакет
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uploadedBy  Int      // ID админа
  
  // Связи
  items       PackageItem[]       // Лекции в пакете
  purchases   UserPackageAccess[] // Кто купил пакет
  uploader    User                @relation("UploadedPackages", fields: [uploadedBy], references: [id])
}

// Отдельная лекция в пакете
model PackageItem {
  id             Int      @id @default(autoincrement())
  packageId      Int      // К какому пакету относится
  title          String   // "Лекция 1: Основы"
  fileName       String   // "lecture_01_compressed.mp3"
  originalName   String   @default("") // Оригинальное имя файла
  filePath       String   // Путь к файлу
  duration       Int?     // Длительность в секундах
  orderIndex     Int      // Порядок в пакете (1, 2, 3...)
  originalSize   BigInt   // Changed to BigInt for files > 2GB
  compressedSize BigInt   // Changed to BigInt for files > 2GB
  createdAt      DateTime @default(now())
  
  // Связи
  package        ContentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  @@index([packageId, orderIndex])
  @@index([packageId, originalName, originalSize]) // Индекс для быстрого поиска дубликатов
}

// Записи учебного класса
model ClassFile {
  id           Int      @id @default(autoincrement())
  displayName  String
  originalName String
  systemName   String   @unique
  uploadedAt   DateTime @default(now())
  uploadedBy   Int
  size         BigInt
  views        Int      @default(0)
  duration     Int?
  isPublic     Boolean  @default(false)
  orderIndex   Int      @default(0)    // Кастомный порядок сортировки
}

// Ссылки на трансляцию учебного класса (отдельно от Служб)
model ClassStreamLink {
  id         Int      @id @default(autoincrement())
  youtubeUrl String?
  rutubeUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Сообщения чата
model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  text      String
  link      String?
  reactions String   @default("{}") // JSON: { "like": [userId, ...], "heart": [...], ... }
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// Покупки пользователей (доступ к пакетам)
model UserPackageAccess {
  id           Int      @id @default(autoincrement())
  userId       Int      // Кто купил
  packageId    Int      // Какой пакет купил
  purchaseDate DateTime @default(now())
  price        Decimal  // За сколько купил
  grantedBy    Int      // Какой админ дал доступ
  notes        String?  // Заметки (способ оплаты, комментарии)
  
  // Связи
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  package      ContentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  admin        User           @relation("GrantedPackageAccess", fields: [grantedBy], references: [id])
  
  @@unique([userId, packageId])
  @@index([userId])
  @@index([packageId])
}
